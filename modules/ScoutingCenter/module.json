{
    "key": "scouting-center",
    "name": "ScoutingCenter",
    "version": "1.0.0",
    "description": "Adds scouting discovery, watchlists, and reporting workflows to the market shell.",
    "enabled": true,
    "providers": [],
    "routes": "routes/web.php",
    "frontend": {
        "manager_navigation": {
            "mod_scouting_center": {
                "label": "Scouting",
                "target_group": "bg_markt",
                "items": [
                    {
                        "route": "scouting.index",
                        "label": "Scouting",
                        "active": "scouting.*"
                    }
                ]
            }
        },
        "admin_navigation": {},
        "dashboard_widgets": [
            {
                "key": "scouting-center-desk",
                "title": "Scouting Desk",
                "description": "Scan markets, review discoveries, and advance active missions.",
                "route": "scouting.index",
                "accent": "emerald",
                "icon": "binoculars",
                "placement": "main",
                "priority": 30,
                "enabled_when": "simulation.modules.scouting_center.dashboard_widget_enabled"
            }
        ],
        "settings_sections": [
            {
                "key": "scouting-center-visibility",
                "title": "Scouting Center",
                "description": "Control scouting discovery visibility on the manager dashboard.",
                "fields": [
                    {
                        "key": "simulation.modules.scouting_center.dashboard_widget_enabled",
                        "label": "Dashboard widget anzeigen",
                        "description": "Zeigt das Scouting-Desk im Dashboard an.",
                        "type": "boolean",
                        "default": true
                    },
                    {
                        "key": "simulation.modules.scouting_center.default_market",
                        "label": "Standardmarkt",
                        "description": "Voreinstellung fuer neu geoeffnete Scouting-Ansichten.",
                        "type": "select",
                        "default": "domestic",
                        "options": ["domestic", "continental", "global"]
                    },
                    {
                        "key": "simulation.modules.scouting_center.default_discovery_level",
                        "label": "Standard-Scout-Linse",
                        "description": "Welche Scout-Linse initial vorausgewaehlt wird.",
                        "type": "select",
                        "default": "experienced",
                        "options": ["junior", "experienced", "elite"]
                    },
                    {
                        "key": "simulation.modules.scouting_center.target_limit",
                        "label": "Zielmarkt-Limit",
                        "description": "Maximale Anzahl an Zielmarkt-Spielern pro Request.",
                        "type": "integer",
                        "default": 24,
                        "min": 8,
                        "max": 60,
                        "step": 1
                    },
                    {
                        "key": "simulation.modules.scouting_center.scout_slots",
                        "label": "Scout-Slots",
                        "description": "Wie viele Scouts dem Verein maximal zur Verfuegung stehen.",
                        "type": "integer",
                        "default": 3,
                        "min": 1,
                        "max": 6,
                        "step": 1
                    },
                    {
                        "key": "simulation.modules.scouting_center.discovery_limit",
                        "label": "Discovery-Board-Limit",
                        "description": "Wie viele persistierte Scout-Leads pro Marktansicht gezeigt werden.",
                        "type": "integer",
                        "default": 12,
                        "min": 4,
                        "max": 30,
                        "step": 1
                    },
                    {
                        "key": "simulation.modules.scouting_center.discovery_note_prefix",
                        "label": "Discovery-Prefix",
                        "description": "Optionaler Text, der Scout-Einschaetzungen vorangestellt wird.",
                        "type": "text",
                        "default": "",
                        "max_length": 80
                    }
                ]
            }
        ],
        "player_actions": [
            {
                "key": "scouting-center-watchlist",
                "title": "Zur Watchlist",
                "description": "Fuegt den Spieler direkt zur Scouting-Watchlist hinzu.",
                "route": "scouting.watchlist.store",
                "method": "post",
                "accent": "emerald",
                "icon": "binoculars",
                "scope": "external_only",
                "placement": "overview",
                "payload": {
                    "priority": "medium",
                    "status": "watching",
                    "focus": "general",
                    "scout_level": "experienced",
                    "scout_region": "continental",
                    "scout_type": "data",
                    "notes": "Direkt aus dem Spielerprofil auf die Watchlist gesetzt."
                }
            }
        ],
        "matchcenter_panels": [],
        "notifications": [
            {
                "type": "scouting_update",
                "label": "Scout-Update",
                "accent": "border-l-emerald-400",
                "icon": "binoculars",
                "icon_wrap": "border border-emerald-400/20 bg-emerald-400/10 text-emerald-300 shadow-[0_0_18px_rgba(52,211,153,0.12)]",
                "badge": "border border-emerald-400/20 bg-emerald-400/10 text-emerald-200"
            }
        ]
    }
}
